{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "DustDesk",
  "version": "0.1.0",
  "identifier": "com.dustdesk.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "DeskNest",
        "width": 1320,
        "height": 820,
        "minWidth": 1080,
        "minHeight": 680,
        "resizable": true,
        "center": true,
        "decorations": false,
        "transparent": false
      },
      {
        "label": "clipboard",
        "title": "DeskNest Clipboard",
        "url": "index.html#/clipboard-overlay",
        "width": 1600,
        "height": 300,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "focus": false,
        "transparent": false
      },
      {
        "label": "search",
        "title": "DeskNest Search",
        "url": "index.html#/search-overlay",
        "width": 860,
        "height": 620,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "focus": true,
        "transparent": false
      },
      {
        "label": "desktop-widget",
        "title": "DustDesk Desktop Widget",
        "url": "index.html#/desktop-widget",
        "width": 720,
        "height": 460,
        "x": -32000,
        "y": -32000,
        "minWidth": 520,
        "minHeight": 320,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "skipTaskbar": true,
        "visible": true,
        "focus": false,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "DustDesk",
    "category": "Productivity",
    "icon": ["icons/icon.ico"],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "nsis": {
        "installMode": "currentUser",
        "languages": ["SimpChinese", "English"],
        "displayLanguageSelector": true,
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico",
        "startMenuFolder": "DustDesk"
      }
    }
  }
}
